[Unit]
Description=A9 mobile/control-plane HTTP API
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/a9
EnvironmentFile=-/root/a9/.env
ExecStart=/root/a9/scripts/a9_control_api.py serve --host 0.0.0.0 --port 8787
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
